{
  "name": "photobot-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered photography community Discord bot with admin dashboard",
  "license": "MIT",
  "author": "Kevin Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinkiklee/photobot.git"
  },
  "homepage": "https://github.com/kevinkiklee/photobot#readme",
  "bugs": {
    "url": "https://github.com/kevinkiklee/photobot/issues"
  },
  "keywords": [
    "discord",
    "bot",
    "photography",
    "ai",
    "gemini",
    "nextjs",
    "prisma"
  ],
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "init:local": "./scripts/setup.sh",
    "dev": "pnpm -r dev",
    "dev:local": "./scripts/dev.sh 2>&1 | tee /tmp/photobot-dev.log",
    "dev:down": "docker compose down",
    "build": "pnpm --filter @photobot/db build && pnpm --filter @photobot/ai build && pnpm --filter @photobot/bot build && pnpm --filter @photobot/dashboard build",
    "test": "vitest run",
    "test:integration": "DATABASE_URL=postgresql://postgres:postgres@localhost:54422/postgres vitest run --workspace vitest.integration.workspace.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "status": "./scripts/status.sh",
    "db": "./scripts/db.sh",
    "cleanup": "./scripts/cleanup.sh",
    "seed:prompts": "tsx scripts/seed-prompts.ts"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "vitest": "^1.0.0"
  }
}
