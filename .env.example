# ======================
# Photobot Environment Variables
# ======================
# Copy this file to .env and fill in the values.

# --- Discord ---
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# --- Database (Supabase / Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54422/postgres

# --- NextAuth (Dashboard) ---
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3100

# --- Supabase (Dashboard Auth Adapter) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI Provider (Production) ---
GEMINI_API_KEY=your-gemini-api-key

# --- AI Provider (Local Dev - Ollama) ---
# Ollama runs via Docker on port 11434.
# No API key needed for local development.
OLLAMA_HOST=http://localhost:11434
