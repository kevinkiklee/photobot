# ======================
# Photobot Environment Variables
# ======================
# Copy this file to .env and fill in the values.
# Or run `pnpm init:local` for interactive setup.

# --- Discord ---
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# --- Database (Supabase / Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54422/postgres

# --- NextAuth (Dashboard) ---
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3100

# --- Supabase (Dashboard Auth Adapter) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Photography Lounge ---
PL_GUILD_ID=your-photography-lounge-server-id
DEV_GUILD_ID=                                  # Optional: dev server ID (bot accepts commands here too)
DEV_STAFF_ROLE_IDS=                            # Optional: comma-separated dev-server role IDs treated as staff for /discuss

# --- Voting App ---
VOTING_NEXTAUTH_SECRET=generate-a-separate-secret
VOTING_ADMIN_USER_IDS=              # Comma-separated Discord user IDs for admin access
VOTING_ADMIN_ROLE_IDS=role-id-1,role-id-2
