# ======================
# Photobot Environment Variables
# ======================
# Copy this file to .env and fill in the values.
# Or run `pnpm init:local` for interactive setup.

# --- Discord ---
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# --- Database (Supabase / Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54422/postgres

# --- NextAuth (Dashboard) ---
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3100

# --- Supabase (Dashboard Auth Adapter) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI Provider ---
# Set to "ollama" for local dev (free, runs in Docker)
# Set to "gemini" for production-quality results (requires API key)
AI_PROVIDER=ollama

# Ollama (local dev) — runs via Docker on port 11434, no API key needed
OLLAMA_HOST=http://localhost:11434

# Gemini (production) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
