generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum TargetType {
  SERVER
  ROLE
  CHANNEL
}

model FeatureConfig {
  id         String     @id @default(uuid())
  targetType TargetType @map("target_type")
  targetId   String     @map("target_id") // Discord ID of server, role, or channel
  featureKey String     @map("feature_key")
  isEnabled  Boolean    @default(true) @map("is_enabled")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@unique([targetType, targetId, featureKey])
  @@index([featureKey])
  @@map("feature_configs")
}

model ConfigAuditLog {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  action     String
  targetType TargetType @map("target_type")
  targetId   String     @map("target_id")
  featureKey String     @map("feature_key")
  oldValue   Json?      @map("old_value")
  newValue   Json?      @map("new_value")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("config_audit_logs")
}

model DiscussionConfig {
  /// Always upserted with id = "singleton". DB does not enforce — single upsert
  /// path in /discuss schedule is the only writer (code-review responsibility).
  id                    String   @id
  discussionsChannelId  String   @map("discussions_channel_id")
  loungeChannelId       String   @map("lounge_channel_id")
  categoryFilter        String?  @map("category_filter")
  isActive              Boolean  @default(true) @map("is_active")
  lastUpdatedBy         String   @map("last_updated_by")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("discussion_config")
}

model DiscussionPromptLog {
  id                    String    @id @default(cuid())
  /// The discussions channel ID at the time the row was written. Pre-restructure
  /// (forum-era) rows used this as the channel where the thread lived.
  /// Post-restructure rows record the #discussions text channel where the
  /// cross-post was published; the thread itself lives in #photo-lounge.
  channelId             String    @map("channel_id")
  promptText            String    @map("prompt_text")
  category              String
  /// Discord thread ID. Pre-restructure: thread lived under a forum post in
  /// #discussions. Post-restructure: thread is on the lounge prompt message.
  /// Historical rows are not migrated.
  threadId              String?   @map("thread_id")
  /// Pre-restructure: equal to threadId (the forum post starter == thread).
  /// Stops being written after the channel restructure; retained for audit.
  discussionsMessageId  String?   @map("discussions_message_id")
  /// Post-restructure: the cross-post message ID in the #discussions text
  /// channel (a separate message that embeds the prompt and links to the
  /// thread). Null on pre-restructure rows.
  crossPostMessageId    String?   @map("cross_post_message_id")
  /// Post-restructure: the lounge prompt message ID. Acts as the reply-chain
  /// root for the mirror service. Null on pre-restructure rows.
  loungePromptMessageId String?   @map("lounge_prompt_message_id")
  /// Channel hosting the prompt anchor message — i.e. where replies the mirror
  /// should pick up are posted. For daily-cycle rows this equals
  /// `discussion_config.lounge_channel_id`. For `/discuss post-here` rows it is
  /// whatever channel the command was run in. The mirror keys its active-prompt
  /// lookup off this column.
  promptChannelId       String?   @map("prompt_channel_id")
  /// Last time this prompt was announced in #lounge. Set after every successful
  /// lounge post (including the initial 08:00 announcement). NOT updated on
  /// Discord API failure — failed announcements are retried at the next slot.
  lastAnnouncedAt       DateTime? @map("last_announced_at")
  /// Set when mirroring should stop accepting new replies for this prompt:
  /// the lounge prompt was deleted, the thread auto-archived, or admin
  /// override. The active-prompt query is:
  ///   WHERE mirrorEndedAt IS NULL AND loungePromptMessageId IS NOT NULL
  ///   ORDER BY postedAt DESC LIMIT 1
  mirrorEndedAt         DateTime? @map("mirror_ended_at")
  postedAt              DateTime  @default(now()) @map("posted_at")

  mirroredMessages      MirroredMessage[]

  @@index([postedAt])
  @@index([channelId])
  @@map("discussion_prompt_logs")
}

model MirroredMessage {
  /// Lounge channel message ID — the original message someone posted as a
  /// reply to the prompt (or to a downstream reply already in this set).
  /// PK because there is exactly one mirrored copy per lounge message.
  loungeMessageId   String   @id @map("lounge_message_id")
  /// Thread-side message ID — the bot's mirrored copy.
  threadMessageId   String   @map("thread_message_id")
  /// FK to the prompt log this mirror belongs to. Restrict on delete so that
  /// deleting a prompt log fails noisily while mirrors exist (preserves audit).
  promptLogId       String   @map("prompt_log_id")
  promptLog         DiscussionPromptLog @relation(fields: [promptLogId], references: [id], onDelete: Restrict)
  /// Author of the original lounge message. Snapshot at mirror time — does
  /// NOT update if the user later renames. Documented behavior, not a bug.
  authorId          String   @map("author_id")
  authorDisplayName String   @map("author_display_name")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([promptLogId])
  @@map("mirrored_messages")
}

enum VoteDirection {
  UP
  DOWN
}

model Prompt {
  id                  String       @id @default(cuid())
  text                String       @db.Text
  originalCategory    String       @map("original_category")
  submittedBy         String?      @map("submitted_by")         // Discord user ID, null for seeded prompts
  submittedByUsername  String?      @map("submitted_by_username")
  createdAt           DateTime     @default(now()) @map("created_at")
  tags                PromptTag[]
  votes               PromptVote[]
  duplicateFlags      PromptDuplicateFlag[]
  tagSuggestions      PromptTagSuggestion[]

  @@map("prompts")
}

model PromptTag {
  id       String @id @default(cuid())
  promptId String @map("prompt_id")
  tag      String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, tag])
  @@index([tag])
  @@map("prompt_tags")
}

model PromptVote {
  id              String        @id @default(cuid())
  promptId        String        @map("prompt_id")
  discordUserId   String        @map("discord_user_id")
  discordUsername  String        @map("discord_username")
  vote            VoteDirection
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  prompt          Prompt        @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, discordUserId])
  @@index([discordUserId])
  @@index([promptId])
  @@map("prompt_votes")
}

model PromptDuplicateFlag {
  id            String   @id @default(cuid())
  promptId      String   @map("prompt_id")
  discordUserId String   @map("discord_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, discordUserId])
  @@index([promptId])
  @@map("prompt_duplicate_flags")
}

enum TagSuggestionAction {
  ADD
  REMOVE
}

model PromptTagSuggestion {
  id            String              @id @default(cuid())
  promptId      String              @map("prompt_id")
  tag           String
  action        TagSuggestionAction
  discordUserId String              @map("discord_user_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  prompt        Prompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, tag, discordUserId])
  @@index([promptId, tag])
  @@map("prompt_tag_suggestions")
}
